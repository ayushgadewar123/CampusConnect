# CampusConnect frontend environment
# Copy this file to frontend/.env and edit the values for your machine.

# Backend HTTP base URL used by Axios calls.
# Keep this as the backend host only (no trailing /api).
REACT_APP_API_URL=http://localhost:5000

# Backend URL used by Socket.IO connections.
# Keep this separate so sockets do not accidentally connect to port 3000.
REACT_APP_SOCKET_URL=http://localhost:5000

# UI label shown in the app.
REACT_APP_APP_NAME=CampusConnect

# Demo fallback mode when the backend is offline.
REACT_APP_ENABLE_DEMO=true
